{
  "name": "plotflow",
  "version": "0.1.0",
  "description": "面向独立游戏开发者的叙事分支管理工具",
  "author": "PlotFlow Team",
  "license": "Proprietary",
  "private": true,
  "main": "./out/main/main.js",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dashboard:refresh": "node scripts/progress-dashboard/refresh.mjs",
    "dashboard:dev": "pnpm dashboard:refresh && pnpm --filter @plotflow/progress-dashboard dev",
    "dashboard:build": "pnpm dashboard:refresh && pnpm --filter @plotflow/progress-dashboard build",
    "package": "electron-vite build && electron-builder --config electron-builder.config.js",
    "package:win": "electron-vite build && electron-builder --config electron-builder.config.js --win",
    "package:mac": "electron-vite build && electron-builder --config electron-builder.config.js --mac",
    "package:linux": "electron-vite build && electron-builder --config electron-builder.config.js --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:css": "stylelint \"packages/app/src/**/*.css\"",
    "lint:tokens": "node scripts/check-no-tsx-colors.mjs",
    "lint:layers": "node scripts/check-ui-layer-tokens.mjs",
    "lint:bundle": "node scripts/check-renderer-bundle-budget.mjs",
    "lint:ui-literals": "node scripts/check-ui-literals.mjs",
    "lint:docs": "node scripts/check-doc-mojibake.mjs",
    "generate:schema-validator": "node packages/core/scripts/generate-story-schema-validator.mjs",
    "check:schema-validator": "node packages/core/scripts/generate-story-schema-validator.mjs --check",
    "check:schema": "node scripts/sync-story-schema.mjs --check && pnpm check:schema-validator",
    "test:engine-contract": "node --test tests/engine-contract/engine-contract.test.mjs",
    "test:external-review-contract": "node --test scripts/external-review/*.test.mjs",
    "external-review:finalize": "node scripts/external-review/finalize-evidence.mjs",
    "external-review:verify": "node scripts/external-review/verify-evidence.mjs",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-builder-squirrel-windows": "26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^8.0.0",
    "husky": "^9.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "typescript": "^5.3.0",
    "vite": "6.4.3",
    "vitest": "^3.2.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ]
  }
}
