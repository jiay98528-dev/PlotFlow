{
  "name": "@plotflow/app",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "node ../../scripts/clean-app-local-out.mjs && pnpm --dir ../.. build",
    "test:e2e": "playwright test --config e2e/playwright.config.ts --workers=1",
    "test:e2e:blackbox": "playwright test --config e2e-blackbox/playwright.config.ts --workers=1 --grep-invert @packaged",
    "test:e2e:unpacked": "set PLOTFLOW_BLACKBOX_TARGET=winUnpacked&& playwright test --config e2e-blackbox/playwright.config.ts --workers=1 --grep-invert @installed",
    "test:e2e:installed": "set PLOTFLOW_BLACKBOX_TARGET=installedExe&& playwright test --config e2e-blackbox/playwright.config.ts --workers=1 --grep-invert @unpacked",
    "test:e2e:blackbox:journey": "playwright test --config e2e-blackbox/playwright.config.ts --workers=1 --grep @journey",
    "test:e2e:blackbox:edge": "playwright test --config e2e-blackbox/playwright.config.ts --workers=1 --grep @edge",
    "test:e2e:blackbox:perf": "playwright test --config e2e-blackbox/playwright.config.ts --workers=1 --grep @perf",
    "test:e2e:ghost": "playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.0.0",
    "@monaco-editor/react": "^4.6.0",
    "@plotflow/core": "workspace:*",
    "@xyflow/react": "^12.0.0",
    "adm-zip": "^0.5.17",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^1.18.0",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "ajv": "8.20.0",
    "electron": "^42.5.0",
    "electron-vite": "^5.0.0",
    "playwright": "1.61.1",
    "vite": "^6.4.3"
  }
}
