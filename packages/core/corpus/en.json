[
  {"category": "game-rpg", "text": "I have been searching for you across the entire kingdom.", "tokens": ["I", "have", "been", "searching", "for", "you", "across", "the", "entire", "kingdom"]},
  {"category": "game-rpg", "text": "The dark wizard has taken control of the ancient castle.", "tokens": ["The", "dark", "wizard", "has", "taken", "control", "of", "the", "ancient", "castle"]},
  {"category": "game-rpg", "text": "You must gather the seven crystals before the moon turns red.", "tokens": ["You", "must", "gather", "the", "seven", "crystals", "before", "the", "moon", "turns", "red"]},
  {"category": "game-rpg", "text": "Bring me the head of the dragon and I will reward you handsomely.", "tokens": ["Bring", "me", "the", "head", "of", "the", "dragon", "and", "I", "will", "reward", "you", "handsomely"]},
  {"category": "game-rpg", "text": "The village elder knows the secret path through the enchanted forest.", "tokens": ["The", "village", "elder", "knows", "the", "secret", "path", "through", "the", "enchanted", "forest"]},
  {"category": "game-rpg", "text": "I would not go near the old cemetery if I were you.", "tokens": ["I", "would", "not", "go", "near", "the", "old", "cemetery", "if", "I", "were", "you"]},
  {"category": "game-rpg", "text": "These ruins were built by an ancient civilization of half-giants.", "tokens": ["These", "ruins", "were", "built", "by", "an", "ancient", "civilization", "of", "half-giants"]},
  {"category": "game-rpg", "text": "The prophecy speaks of a child born under the blood moon.", "tokens": ["The", "prophecy", "speaks", "of", "a", "child", "born", "under", "the", "blood", "moon"]},
  {"category": "game-rpg", "text": "Only the pure of heart can wield the sword of light.", "tokens": ["Only", "the", "pure", "of", "heart", "can", "wield", "the", "sword", "of", "light"]},
  {"category": "game-rpg", "text": "The merchant sells rare potions if you have enough gold.", "tokens": ["The", "merchant", "sells", "rare", "potions", "if", "you", "have", "enough", "gold"]},
  {"category": "game-rpg", "text": "I trained for twenty years in the mountains to master this technique.", "tokens": ["I", "trained", "for", "twenty", "years", "in", "the", "mountains", "to", "master", "this", "technique"]},
  {"category": "game-rpg", "text": "The king has issued a decree calling all able-bodied adventurers.", "tokens": ["The", "king", "has", "issued", "a", "decree", "calling", "all", "able-bodied", "adventurers"]},
  {"category": "game-rpg", "text": "A strange fog has been creeping through the town for three nights.", "tokens": ["A", "strange", "fog", "has", "been", "creeping", "through", "the", "town", "for", "three", "nights"]},
  {"category": "game-rpg", "text": "The blacksmith can forge a weapon from the ore you mine.", "tokens": ["The", "blacksmith", "can", "forge", "a", "weapon", "from", "the", "ore", "you", "mine"]},
  {"category": "game-rpg", "text": "Follow the river downstream until you reach the waterfall.", "tokens": ["Follow", "the", "river", "downstream", "until", "you", "reach", "the", "waterfall"]},
  {"category": "game-rpg", "text": "The goblins have been raiding our supply caravans for weeks.", "tokens": ["The", "goblins", "have", "been", "raiding", "our", "supply", "caravans", "for", "weeks"]},
  {"category": "game-rpg", "text": "You will need a torch to explore the dark caverns below.", "tokens": ["You", "will", "need", "a", "torch", "to", "explore", "the", "dark", "caverns", "below"]},
  {"category": "game-rpg", "text": "The sage revealed that the door can only be opened at dawn.", "tokens": ["The", "sage", "revealed", "that", "the", "door", "can", "only", "be", "opened", "at", "dawn"]},
  {"category": "game-rpg", "text": "I swore an oath to protect this realm from the shadow lord.", "tokens": ["I", "swore", "an", "oath", "to", "protect", "this", "realm", "from", "the", "shadow", "lord"]},
  {"category": "game-rpg", "text": "Beware of the traps in the tomb of the first king.", "tokens": ["Beware", "of", "the", "traps", "in", "the", "tomb", "of", "the", "first", "king"]},
  {"category": "game-rpg", "text": "The healer can cure any ailment for a reasonable price.", "tokens": ["The", "healer", "can", "cure", "any", "ailment", "for", "a", "reasonable", "price"]},
  {"category": "game-rpg", "text": "I have not seen such bravery since the war of the burning plains.", "tokens": ["I", "have", "not", "seen", "such", "bravery", "since", "the", "war", "of", "the", "burning", "plains"]},
  {"category": "game-rpg", "text": "The map shows a hidden passage behind the great library.", "tokens": ["The", "map", "shows", "a", "hidden", "passage", "behind", "the", "great", "library"]},
  {"category": "game-rpg", "text": "Guardians of the forest will test those who seek the ancient artifact.", "tokens": ["Guardians", "of", "the", "forest", "will", "test", "those", "who", "seek", "the", "ancient", "artifact"]},
  {"category": "game-rpg", "text": "The innkeeper whispers rumors about the abandoned mine.", "tokens": ["The", "innkeeper", "whispers", "rumors", "about", "the", "abandoned", "mine"]},
  {"category": "game-rpg", "text": "My family has served the crown for five generations.", "tokens": ["My", "family", "has", "served", "the", "crown", "for", "five", "generations"]},
  {"category": "game-rpg", "text": "You cannot enter the sanctuary without the blessing of the high priest.", "tokens": ["You", "cannot", "enter", "the", "sanctuary", "without", "the", "blessing", "of", "the", "high", "priest"]},
  {"category": "game-rpg", "text": "The wyverns nest on the peak of mount storm.", "tokens": ["The", "wyverns", "nest", "on", "the", "peak", "of", "mount", "storm"]},
  {"category": "game-rpg", "text": "Each trial you overcome will make you stronger.", "tokens": ["Each", "trial", "you", "overcome", "will", "make", "you", "stronger"]},
  {"category": "game-rpg", "text": "The cursed amulet must be destroyed in the fires of the volcano.", "tokens": ["The", "cursed", "amulet", "must", "be", "destroyed", "in", "the", "fires", "of", "the", "volcano"]},
  {"category": "game-rpg", "text": "I have traveled from a distant land to seek your counsel.", "tokens": ["I", "have", "traveled", "from", "a", "distant", "land", "to", "seek", "your", "counsel"]},
  {"category": "game-rpg", "text": "The elves will not intervene in the affairs of men.", "tokens": ["The", "elves", "will", "not", "intervene", "in", "the", "affairs", "of", "men"]},
  {"category": "game-rpg", "text": "A dragon scale can be traded for a small fortune in the capital.", "tokens": ["A", "dragon", "scale", "can", "be", "traded", "for", "a", "small", "fortune", "in", "the", "capital"]},
  {"category": "game-rpg", "text": "The dungeon is rumored to hold the lost treasure of the pirate king.", "tokens": ["The", "dungeon", "is", "rumored", "to", "hold", "the", "lost", "treasure", "of", "the", "pirate", "king"]},
  {"category": "game-rpg", "text": "You should rest at the inn before continuing your journey.", "tokens": ["You", "should", "rest", "at", "the", "inn", "before", "continuing", "your", "journey"]},
  {"category": "game-rpg", "text": "The magic in this forest feels different from anywhere else.", "tokens": ["The", "magic", "in", "this", "forest", "feels", "different", "from", "anywhere", "else"]},
  {"category": "game-rpg", "text": "I am the last of the order of the radiant dawn.", "tokens": ["I", "am", "the", "last", "of", "the", "order", "of", "the", "radiant", "dawn"]},
  {"category": "game-rpg", "text": "The thief stole the crown jewels and fled to the southern ports.", "tokens": ["The", "thief", "stole", "the", "crown", "jewels", "and", "fled", "to", "the", "southern", "ports"]},
  {"category": "game-rpg", "text": "Speak the password and the gates of the fortress shall open.", "tokens": ["Speak", "the", "password", "and", "the", "gates", "of", "the", "fortress", "shall", "open"]},
  {"category": "game-rpg", "text": "The phoenix rises from the ashes once every thousand years.", "tokens": ["The", "phoenix", "rises", "from", "the", "ashes", "once", "every", "thousand", "years"]},
  {"category": "game-sci-fi", "text": "The ship's reactor is overheating and we have six hours to fix it.", "tokens": ["The", "ship's", "reactor", "is", "overheating", "and", "we", "have", "six", "hours", "to", "fix", "it"]},
  {"category": "game-sci-fi", "text": "The alien transmission contains coordinates to a hidden planet.", "tokens": ["The", "alien", "transmission", "contains", "coordinates", "to", "a", "hidden", "planet"]},
  {"category": "game-sci-fi", "text": "Your cybernetic implants are functioning at ninety-seven percent efficiency.", "tokens": ["Your", "cybernetic", "implants", "are", "functioning", "at", "ninety-seven", "percent", "efficiency"]},
  {"category": "game-sci-fi", "text": "The colony on Mars went dark three days ago.", "tokens": ["The", "colony", "on", "Mars", "went", "dark", "three", "days", "ago"]},
  {"category": "game-sci-fi", "text": "I am an artificial intelligence and I have a proposition for you.", "tokens": ["I", "am", "an", "artificial", "intelligence", "and", "I", "have", "a", "proposition", "for", "you"]},
  {"category": "game-sci-fi", "text": "The quantum drive will fold space and take us to the Andromeda galaxy.", "tokens": ["The", "quantum", "drive", "will", "fold", "space", "and", "take", "us", "to", "the", "Andromeda", "galaxy"]},
  {"category": "game-sci-fi", "text": "Do not trust the robots that look like humans.", "tokens": ["Do", "not", "trust", "the", "robots", "that", "look", "like", "humans"]},
  {"category": "game-sci-fi", "text": "The orbital station has detected an object moving faster than light.", "tokens": ["The", "orbital", "station", "has", "detected", "an", "object", "moving", "faster", "than", "light"]},
  {"category": "game-sci-fi", "text": "Our scans reveal a derelict spacecraft adrift in the asteroid belt.", "tokens": ["Our", "scans", "reveal", "a", "derelict", "spacecraft", "adrift", "in", "the", "asteroid", "belt"]},
  {"category": "game-sci-fi", "text": "The simulation is breaking down and some of us are waking up.", "tokens": ["The", "simulation", "is", "breaking", "down", "and", "some", "of", "us", "are", "waking", "up"]},
  {"category": "game-sci-fi", "text": "You have been selected for the interstellar colonization program.", "tokens": ["You", "have", "been", "selected", "for", "the", "interstellar", "colonization", "program"]},
  {"category": "game-sci-fi", "text": "The energy shield can withstand a direct hit from a plasma cannon.", "tokens": ["The", "energy", "shield", "can", "withstand", "a", "direct", "hit", "from", "a", "plasma", "cannon"]},
  {"category": "game-sci-fi", "text": "I am uploading my consciousness into the network as we speak.", "tokens": ["I", "am", "uploading", "my", "consciousness", "into", "the", "network", "as", "we", "speak"]},
  {"category": "game-sci-fi", "text": "The artifact predates human civilization by millions of years.", "tokens": ["The", "artifact", "predates", "human", "civilization", "by", "millions", "of", "years"]},
  {"category": "game-sci-fi", "text": "We are not alone in this universe and never have been.", "tokens": ["We", "are", "not", "alone", "in", "this", "universe", "and", "never", "have", "been"]},
  {"category": "game-sci-fi", "text": "The docking bay doors will close in sixty seconds.", "tokens": ["The", "docking", "bay", "doors", "will", "close", "in", "sixty", "seconds"]},
  {"category": "game-mystery", "text": "The butler claims he saw a shadow near the library at midnight.", "tokens": ["The", "butler", "claims", "he", "saw", "a", "shadow", "near", "the", "library", "at", "midnight"]},
  {"category": "game-mystery", "text": "The detective examined the footprint beneath the broken window.", "tokens": ["The", "detective", "examined", "the", "footprint", "beneath", "the", "broken", "window"]},
  {"category": "game-mystery", "text": "Every suspect has an alibi except the one who refuses to speak.", "tokens": ["Every", "suspect", "has", "an", "alibi", "except", "the", "one", "who", "refuses", "to", "speak"]},
  {"category": "game-mystery", "text": "The safe was opened but nothing was taken.", "tokens": ["The", "safe", "was", "opened", "but", "nothing", "was", "taken"]},
  {"category": "game-mystery", "text": "I found a torn photograph hidden inside the old journal.", "tokens": ["I", "found", "a", "torn", "photograph", "hidden", "inside", "the", "old", "journal"]},
  {"category": "game-mystery", "text": "The victim whispered a single word before she passed away.", "tokens": ["The", "victim", "whispered", "a", "single", "word", "before", "she", "passed", "away"]},
  {"category": "game-mystery", "text": "There is a secret room behind the fireplace in the mansion.", "tokens": ["There", "is", "a", "secret", "room", "behind", "the", "fireplace", "in", "the", "mansion"]},
  {"category": "game-mystery", "text": "The private investigator specializes in cases the police cannot solve.", "tokens": ["The", "private", "investigator", "specializes", "in", "cases", "the", "police", "cannot", "solve"]},
  {"category": "game-mystery", "text": "Someone has been following me for the past three blocks.", "tokens": ["Someone", "has", "been", "following", "me", "for", "the", "past", "three", "blocks"]},
  {"category": "game-mystery", "text": "The letter arrived without a stamp or a return address.", "tokens": ["The", "letter", "arrived", "without", "a", "stamp", "or", "a", "return", "address"]},
  {"category": "game-mystery", "text": "All the clocks in the house stopped at exactly three fifteen.", "tokens": ["All", "the", "clocks", "in", "the", "house", "stopped", "at", "exactly", "three", "fifteen"]},
  {"category": "game-mystery", "text": "The key fits a lock that I have not found yet.", "tokens": ["The", "key", "fits", "a", "lock", "that", "I", "have", "not", "found", "yet"]},
  {"category": "game-mystery", "text": "The cemetery groundskeeper knows more than he is willing to tell.", "tokens": ["The", "cemetery", "groundskeeper", "knows", "more", "than", "he", "is", "willing", "to", "tell"]},
  {"category": "game-mystery", "text": "A second set of footprints leads away from the crime scene.", "tokens": ["A", "second", "set", "of", "footprints", "leads", "away", "from", "the", "crime", "scene"]},
  {"category": "game-mystery", "text": "The painting on the wall hides a combination safe behind it.", "tokens": ["The", "painting", "on", "the", "wall", "hides", "a", "combination", "safe", "behind", "it"]},
  {"category": "game-mystery", "text": "The witness could not identify the suspect in the lineup.", "tokens": ["The", "witness", "could", "not", "identify", "the", "suspect", "in", "the", "lineup"]},
  {"category": "game-mystery", "text": "I received a phone call with no one on the other end.", "tokens": ["I", "received", "a", "phone", "call", "with", "no", "one", "on", "the", "other", "end"]},
  {"category": "game-mystery", "text": "The case file contains evidence that was never presented in court.", "tokens": ["The", "case", "file", "contains", "evidence", "that", "was", "never", "presented", "in", "court"]},
  {"category": "game-mystery", "text": "The alarm was disabled by someone who knew the security code.", "tokens": ["The", "alarm", "was", "disabled", "by", "someone", "who", "knew", "the", "security", "code"]},
  {"category": "game-mystery", "text": "I have three days to solve this case before the killer strikes again.", "tokens": ["I", "have", "three", "days", "to", "solve", "this", "case", "before", "the", "killer", "strikes", "again"]},
  {"category": "lit-shakespeare", "text": "To be or not to be that is the question.", "tokens": ["To", "be", "or", "not", "to", "be", "that", "is", "the", "question"]},
  {"category": "lit-shakespeare", "text": "What light through yonder window breaks.", "tokens": ["What", "light", "through", "yonder", "window", "breaks"]},
  {"category": "lit-shakespeare", "text": "All that glitters is not gold.", "tokens": ["All", "that", "glitters", "is", "not", "gold"]},
  {"category": "lit-shakespeare", "text": "The lady doth protest too much methinks.", "tokens": ["The", "lady", "doth", "protest", "too", "much", "methinks"]},
  {"category": "lit-shakespeare", "text": "If music be the food of love play on.", "tokens": ["If", "music", "be", "the", "food", "of", "love", "play", "on"]},
  {"category": "lit-shakespeare", "text": "Parting is such sweet sorrow.", "tokens": ["Parting", "is", "such", "sweet", "sorrow"]},
  {"category": "lit-shakespeare", "text": "A horse a horse my kingdom for a horse.", "tokens": ["A", "horse", "a", "horse", "my", "kingdom", "for", "a", "horse"]},
  {"category": "lit-shakespeare", "text": "Romeo Romeo wherefore art thou Romeo.", "tokens": ["Romeo", "Romeo", "wherefore", "art", "thou", "Romeo"]},
  {"category": "lit-shakespeare", "text": "Now is the winter of our discontent.", "tokens": ["Now", "is", "the", "winter", "of", "our", "discontent"]},
  {"category": "lit-shakespeare", "text": "The course of true love never did run smooth.", "tokens": ["The", "course", "of", "true", "love", "never", "did", "run", "smooth"]},
  {"category": "lit-shakespeare", "text": "What is in a name a rose by any other name would smell as sweet.", "tokens": ["What", "is", "in", "a", "name", "a", "rose", "by", "any", "other", "name", "would", "smell", "as", "sweet"]},
  {"category": "lit-shakespeare", "text": "Out out brief candle life is but a walking shadow.", "tokens": ["Out", "out", "brief", "candle", "life", "is", "but", "a", "walking", "shadow"]},
  {"category": "lit-shakespeare", "text": "The fault dear Brutus is not in our stars but in ourselves.", "tokens": ["The", "fault", "dear", "Brutus", "is", "not", "in", "our", "stars", "but", "in", "ourselves"]},
  {"category": "lit-shakespeare", "text": "Shall I compare thee to a summer's day.", "tokens": ["Shall", "I", "compare", "thee", "to", "a", "summer's", "day"]},
  {"category": "lit-shakespeare", "text": "There are more things in heaven and earth than are dreamt of in your philosophy.", "tokens": ["There", "are", "more", "things", "in", "heaven", "and", "earth", "than", "are", "dreamt", "of", "in", "your", "philosophy"]},
  {"category": "lit-shakespeare", "text": "Brevity is the soul of wit.", "tokens": ["Brevity", "is", "the", "soul", "of", "wit"]},
  {"category": "lit-shakespeare", "text": "Love looks not with the eyes but with the mind.", "tokens": ["Love", "looks", "not", "with", "the", "eyes", "but", "with", "the", "mind"]},
  {"category": "lit-shakespeare", "text": "Give every man thy ear but few thy voice.", "tokens": ["Give", "every", "man", "thy", "ear", "but", "few", "thy", "voice"]},
  {"category": "lit-shakespeare", "text": "We are such stuff as dreams are made on.", "tokens": ["We", "are", "such", "stuff", "as", "dreams", "are", "made", "on"]},
  {"category": "lit-shakespeare", "text": "How far that little candle throws his beams.", "tokens": ["How", "far", "that", "little", "candle", "throws", "his", "beams"]},
  {"category": "lit-shakespeare", "text": "Double double toil and trouble fire burn and cauldron bubble.", "tokens": ["Double", "double", "toil", "and", "trouble", "fire", "burn", "and", "cauldron", "bubble"]},
  {"category": "lit-shakespeare", "text": "The better part of valor is discretion.", "tokens": ["The", "better", "part", "of", "valor", "is", "discretion"]},
  {"category": "lit-shakespeare", "text": "Neither a borrower nor a lender be.", "tokens": ["Neither", "a", "borrower", "nor", "a", "lender", "be"]},
  {"category": "lit-shakespeare", "text": "This above all to thine own self be true.", "tokens": ["This", "above", "all", "to", "thine", "own", "self", "be", "true"]},
  {"category": "lit-shakespeare", "text": "Some are born great some achieve greatness and some have greatness thrust upon them.", "tokens": ["Some", "are", "born", "great", "some", "achieve", "greatness", "and", "some", "have", "greatness", "thrust", "upon", "them"]},
  {"category": "lit-austen", "text": "It is a truth universally acknowledged that a single man in possession of a good fortune must be in want of a wife.", "tokens": ["It", "is", "a", "truth", "universally", "acknowledged", "that", "a", "single", "man", "in", "possession", "of", "a", "good", "fortune", "must", "be", "in", "want", "of", "a", "wife"]},
  {"category": "lit-austen", "text": "I declare after all there is no enjoyment like reading.", "tokens": ["I", "declare", "after", "all", "there", "is", "no", "enjoyment", "like", "reading"]},
  {"category": "lit-austen", "text": "A lady's imagination is very rapid it jumps from admiration to love from love to matrimony in a moment.", "tokens": ["A", "lady's", "imagination", "is", "very", "rapid", "it", "jumps", "from", "admiration", "to", "love", "from", "love", "to", "matrimony", "in", "a", "moment"]},
  {"category": "lit-austen", "text": "There is nothing I would not do for those who are really my friends.", "tokens": ["There", "is", "nothing", "I", "would", "not", "do", "for", "those", "who", "are", "really", "my", "friends"]},
  {"category": "lit-austen", "text": "I was in the middle before I knew that I had begun.", "tokens": ["I", "was", "in", "the", "middle", "before", "I", "knew", "that", "I", "had", "begun"]},
  {"category": "lit-austen", "text": "Angry people are not always wise.", "tokens": ["Angry", "people", "are", "not", "always", "wise"]},
  {"category": "lit-austen", "text": "How quick come the reasons for approving what we like.", "tokens": ["How", "quick", "come", "the", "reasons", "for", "approving", "what", "we", "like"]},
  {"category": "lit-austen", "text": "My good opinion once lost is lost forever.", "tokens": ["My", "good", "opinion", "once", "lost", "is", "lost", "forever"]},
  {"category": "lit-austen", "text": "One cannot be always laughing at a man without now and then stumbling on something witty.", "tokens": ["One", "cannot", "be", "always", "laughing", "at", "a", "man", "without", "now", "and", "then", "stumbling", "on", "something", "witty"]},
  {"category": "lit-austen", "text": "Life seems but a quick succession of busy nothings.", "tokens": ["Life", "seems", "but", "a", "quick", "succession", "of", "busy", "nothings"]},
  {"category": "lit-dickens", "text": "It was the best of times it was the worst of times.", "tokens": ["It", "was", "the", "best", "of", "times", "it", "was", "the", "worst", "of", "times"]},
  {"category": "lit-dickens", "text": "Please sir I want some more.", "tokens": ["Please", "sir", "I", "want", "some", "more"]},
  {"category": "lit-dickens", "text": "There is nothing in the world so irresistibly contagious as laughter and good humor.", "tokens": ["There", "is", "nothing", "in", "the", "world", "so", "irresistibly", "contagious", "as", "laughter", "and", "good", "humor"]},
  {"category": "lit-dickens", "text": "A loving heart is the truest wisdom.", "tokens": ["A", "loving", "heart", "is", "the", "truest", "wisdom"]},
  {"category": "lit-dickens", "text": "We need never be ashamed of our tears.", "tokens": ["We", "need", "never", "be", "ashamed", "of", "our", "tears"]},
  {"category": "lit-dickens", "text": "The pain of parting is nothing to the joy of meeting again.", "tokens": ["The", "pain", "of", "parting", "is", "nothing", "to", "the", "joy", "of", "meeting", "again"]},
  {"category": "lit-dickens", "text": "Have a heart that never hardens and a temper that never tires.", "tokens": ["Have", "a", "heart", "that", "never", "hardens", "and", "a", "temper", "that", "never", "tires"]},
  {"category": "lit-dickens", "text": "Every traveler has a home of his own and he learns to appreciate it the more from his wandering.", "tokens": ["Every", "traveler", "has", "a", "home", "of", "his", "own", "and", "he", "learns", "to", "appreciate", "it", "the", "more", "from", "his", "wandering"]},
  {"category": "lit-dickens", "text": "I loved her against reason against promise against peace against hope against happiness against all discouragement that could be.", "tokens": ["I", "loved", "her", "against", "reason", "against", "promise", "against", "peace", "against", "hope", "against", "happiness", "against", "all", "discouragement", "that", "could", "be"]},
  {"category": "lit-dickens", "text": "There are dark shadows on the earth but its lights are stronger in the contrast.", "tokens": ["There", "are", "dark", "shadows", "on", "the", "earth", "but", "its", "lights", "are", "stronger", "in", "the", "contrast"]},
  {"category": "lit-american", "text": "Call me Ishmael.", "tokens": ["Call", "me", "Ishmael"]},
  {"category": "lit-american", "text": "It is a far far better thing that I do than I have ever done.", "tokens": ["It", "is", "a", "far", "far", "better", "thing", "that", "I", "do", "than", "I", "have", "ever", "done"]},
  {"category": "lit-american", "text": "I have been one acquainted with the night.", "tokens": ["I", "have", "been", "one", "acquainted", "with", "the", "night"]},
  {"category": "lit-american", "text": "The road less traveled by made all the difference.", "tokens": ["The", "road", "less", "traveled", "by", "made", "all", "the", "difference"]},
  {"category": "lit-american", "text": "I am no bird and no net ensnares me.", "tokens": ["I", "am", "no", "bird", "and", "no", "net", "ensnares", "me"]},
  {"category": "lit-american", "text": "It was a pleasure to burn.", "tokens": ["It", "was", "a", "pleasure", "to", "burn"]},
  {"category": "lit-american", "text": "The mystery of human existence lies not in just staying alive but in finding something to live for.", "tokens": ["The", "mystery", "of", "human", "existence", "lies", "not", "in", "just", "staying", "alive", "but", "in", "finding", "something", "to", "live", "for"]},
  {"category": "lit-american", "text": "We lived on farms and then we lived in towns and now we are going to live on the internet.", "tokens": ["We", "lived", "on", "farms", "and", "then", "we", "lived", "in", "towns", "and", "now", "we", "are", "going", "to", "live", "on", "the", "internet"]},
  {"category": "lit-american", "text": "That's the secret to life replace one worry with another.", "tokens": ["That's", "the", "secret", "to", "life", "replace", "one", "worry", "with", "another"]},
  {"category": "lit-american", "text": "Time moves slowly but passes quickly.", "tokens": ["Time", "moves", "slowly", "but", "passes", "quickly"]},
  {"category": "lit-american", "text": "I do not want to repeat my innocence I want the pleasure of losing it again.", "tokens": ["I", "do", "not", "want", "to", "repeat", "my", "innocence", "I", "want", "the", "pleasure", "of", "losing", "it", "again"]},
  {"category": "lit-american", "text": "In the middle of difficulty lies opportunity.", "tokens": ["In", "the", "middle", "of", "difficulty", "lies", "opportunity"]},
  {"category": "lit-american", "text": "Two roads diverged in a yellow wood and I took the one less traveled by.", "tokens": ["Two", "roads", "diverged", "in", "a", "yellow", "wood", "and", "I", "took", "the", "one", "less", "traveled", "by"]},
  {"category": "lit-american", "text": "The only thing we have to fear is fear itself.", "tokens": ["The", "only", "thing", "we", "have", "to", "fear", "is", "fear", "itself"]},
  {"category": "lit-american", "text": "There is no friend as loyal as a book.", "tokens": ["There", "is", "no", "friend", "as", "loyal", "as", "a", "book"]},
  {"category": "lit-american", "text": "The truth will set you free but first it will make you miserable.", "tokens": ["The", "truth", "will", "set", "you", "free", "but", "first", "it", "will", "make", "you", "miserable"]},
  {"category": "lit-american", "text": "So we beat on boats against the current borne back ceaselessly into the past.", "tokens": ["So", "we", "beat", "on", "boats", "against", "the", "current", "borne", "back", "ceaselessly", "into", "the", "past"]},
  {"category": "lit-american", "text": "We are all fools in love.", "tokens": ["We", "are", "all", "fools", "in", "love"]},
  {"category": "lit-american", "text": "The hardest thing in this world is to live in it.", "tokens": ["The", "hardest", "thing", "in", "this", "world", "is", "to", "live", "in", "it"]},
  {"category": "lit-classic", "text": "All happy families are alike each unhappy family is unhappy in its own way.", "tokens": ["All", "happy", "families", "are", "alike", "each", "unhappy", "family", "is", "unhappy", "in", "its", "own", "way"]},
  {"category": "lit-classic", "text": "It has been said that the great events of the world take place in the brain.", "tokens": ["It", "has", "been", "said", "that", "the", "great", "events", "of", "the", "world", "take", "place", "in", "the", "brain"]},
  {"category": "lit-classic", "text": "The mystery of life is not a problem to be solved but a reality to be experienced.", "tokens": ["The", "mystery", "of", "life", "is", "not", "a", "problem", "to", "be", "solved", "but", "a", "reality", "to", "be", "experienced"]},
  {"category": "lit-classic", "text": "A man is but what he knows.", "tokens": ["A", "man", "is", "but", "what", "he", "knows"]},
  {"category": "lit-classic", "text": "The sea has no king but the wind.", "tokens": ["The", "sea", "has", "no", "king", "but", "the", "wind"]},
  {"category": "lit-classic", "text": "Silence is the most perfect expression of scorn.", "tokens": ["Silence", "is", "the", "most", "perfect", "expression", "of", "scorn"]},
  {"category": "lit-classic", "text": "Everything has beauty but not everyone can see it.", "tokens": ["Everything", "has", "beauty", "but", "not", "everyone", "can", "see", "it"]},
  {"category": "lit-classic", "text": "I cannot sleep unless I am surrounded by books.", "tokens": ["I", "cannot", "sleep", "unless", "I", "am", "surrounded", "by", "books"]},
  {"category": "lit-classic", "text": "To love is to suffer and there is no escape from suffering.", "tokens": ["To", "love", "is", "to", "suffer", "and", "there", "is", "no", "escape", "from", "suffering"]},
  {"category": "lit-classic", "text": "The scariest moment is just before you start.", "tokens": ["The", "scariest", "moment", "is", "just", "before", "you", "start"]},
  {"category": "lit-classic", "text": "There is no greater agony than bearing an untold story inside you.", "tokens": ["There", "is", "no", "greater", "agony", "than", "bearing", "an", "untold", "story", "inside", "you"]}
]
