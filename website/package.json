{
  "name": "plotflow-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PlotFlow independent landing page and user guide site.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "sync:data": "node scripts/sync-project-status.mjs",
    "serve:dist": "node scripts/serve-dist.mjs",
    "build:static": "node scripts/build-static.mjs",
    "verify:static": "node scripts/verify-static.mjs",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc --noEmit && vite build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.2.0",
    "lucide-react": "1.18.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "vite": "6.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.3.0",
    "vitest": "3.2.6"
  }
}
